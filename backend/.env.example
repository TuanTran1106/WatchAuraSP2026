# ================================================
# VNPay Configuration
# ================================================
# Đăng ký tài khoản VNPay Merchant:
# - Sandbox: https://sandbox.vnpayment.vn/merchant/register
# - Production: https://merchant.vnpay.vn/
#
# Sau khi đăng ký và được duyệt, bạn sẽ nhận được:
# - TMN Code: Mã website/merchant của bạn
# - Hash Secret: Khóa bí mật để ký HMAC SHA512

# TMN Code (bắt buộc)
VNPAY_TMN_CODE=YOUR_TMN_CODE_HERE

# Hash Secret (bắt buộc)
VNPAY_HASH_SECRET=YOUR_HASH_SECRET_HERE

# URL thanh toán VNPay
# Sandbox (test):
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production (thật):
# VNPAY_URL=https://pay.vnpay.vn/vpcpay.html

# Return URL (VNPay redirect về sau khi thanh toán)
# Thay đổi domain khi deploy
VNPAY_RETURN_URL=http://localhost:8080/thanh-toan/vnpay/return

# ================================================
# Database Configuration
# ================================================
DB_URL=jdbc:sqlserver://localhost:1433;databaseName=WATCHAURA_STORE2;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
